APP_ENV=local
API_BASE_URL=http://localhost:8000

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_STORAGE_BUCKET=user-files

WECHAT_APP_ID=replace-with-wechat-app-id
WECHAT_APP_SECRET=replace-with-wechat-app-secret

DEEPSEEK_API_KEY=replace-with-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OCR_PROVIDER=tencent
TENCENT_SECRET_ID=replace-with-tencent-secret-id
TENCENT_SECRET_KEY=replace-with-tencent-secret-key
TENCENT_REGION=ap-guangzhou
